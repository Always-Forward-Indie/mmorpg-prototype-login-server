# Login Server Configuration
# Copy this file to .env and fill in real values

# Database
DB_NAME=mmo_prototype
DB_USER=postgres
DB_PASSWORD=CHANGE_ME
DB_HOST=127.0.0.1
DB_PORT=5432

# Login Server
SERVER_HOST=0.0.0.0
SERVER_PORT=27014
SERVER_MAX_CLIENTS=3000
MIN_CLIENT_VERSION=0.1.0
MAX_CLIENT_VERSION=0.1.0

# Logging
LOG_LEVEL=info
LOG_LEVEL_NETWORK=warn
LOG_LEVEL_GAMELOOP=warn
LOG_LEVEL_EVENTS=warn
